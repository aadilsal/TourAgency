# Next.js (public)
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Email (Convex actions)
RESEND_API_KEY=
RESEND_FROM=JunketTours <bookings@yourdomain.com>
ADMIN_NOTIFICATION_EMAIL=you@yourdomain.com
APP_BASE_URL=https://your-app.vercel.app

# AI (Convex actions)
GROQ_API_KEY=

# One-time bootstrap (Convex action bootstrapSuperAdmin), then remove
BOOTSTRAP_SECRET=

# Optional: shown in footer (display string, e.g. +92 300 1234567)
NEXT_PUBLIC_CONTACT_PHONE=

# Footer map: Google Maps embed src URL + human-readable address line
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_URL=
NEXT_PUBLIC_OFFICE_ADDRESS=

# WhatsApp click-to-chat (optional; defaults to +923209973486 if unset)
WHATSAPP_BUSINESS_NUMBER=
